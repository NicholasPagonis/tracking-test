{
  "name": "airport-tracking",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:api": "npm run start --workspace=apps/api",
    "start:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces --if-present",
    "sim": "npm run start --workspace=packages/simulator",
    "migrate": "npm run migrate --workspace=apps/api",
    "seed": "npm run seed --workspace=apps/api",
    "lint": "eslint 'apps/**/*.js' 'packages/**/*.js'"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
