# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────────────────────────
# Internal connection URL from Dokploy database → General → Internal Connection URL
DATABASE_URL=postgresql://postgres:password@tracking-test-database-exlcxa:5432/db

# ─── Authentication ────────────────────────────────────────────────────────────
# Dashboard and read-only API access
API_KEY_DASHBOARD=changeme-dashboard-key-at-least-32-chars
# Admin endpoints (device management, manual sync triggers)
API_KEY_ADMIN=changeme-admin-key-at-least-32-chars

# ─── Status Thresholds ─────────────────────────────────────────────────────────
# Seconds since last update before transitioning states
STATUS_ACTIVE_SECONDS=180
STATUS_STALE_SECONDS=600

# ─── History Retention ─────────────────────────────────────────────────────────
HISTORY_RETENTION_HOURS=24
PRUNE_INTERVAL_MINUTES=30

# ─── ArcGIS ────────────────────────────────────────────────────────────────────
ARCGIS_ENABLED=false
ARCGIS_FEATURE_SERVICE_URL=https://services.arcgis.com/<org>/arcgis/rest/services/<layer>/FeatureServer/0
ARCGIS_CLIENT_ID=
ARCGIS_CLIENT_SECRET=
ARCGIS_TOKEN_URL=https://www.arcgis.com/sharing/rest/oauth2/token
ARCGIS_SYNC_INTERVAL_SECONDS=30

# ─── WebEOC ────────────────────────────────────────────────────────────────────
WEBEOC_ENABLED=false
WEBEOC_BASE_URL=https://webeoc.example.com/api
WEBEOC_USERNAME=
WEBEOC_PASSWORD=
WEBEOC_BOARD_NAME=AirportOperations

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL_MS=30000

# ─── Simulator ─────────────────────────────────────────────────────────────────
# Set in packages/simulator/.env or pass as environment to docker-compose
SIMULATOR_API_BASE_URL=http://localhost:3000
SIMULATOR_INTERVAL_MS=5000
SIMULATOR_SCENARIO=normal-ops
AIRPORT_CENTER_LAT=-33.9399
AIRPORT_CENTER_LON=151.1753
